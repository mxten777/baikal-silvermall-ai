NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...
SUPABASE_SERVICE_ROLE_KEY=eyJhb...  # 절대 클라이언트에 노출 금지

# Toss Payments
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...    # 클라이언트 키 (공개 가능)
TOSS_SECRET_KEY=test_sk_...                # 서버 전용 (절대 노출 금지)
TOSS_WEBHOOK_SECRET=whsec_...              # 웹훅 서명 검증

# Sentry
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Playwright E2E
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test1234!
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=admin1234!
TEST_PRODUCT_ID=uuid-of-test-product

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=실버몰 - 복지용구 전문 쇼핑몰
